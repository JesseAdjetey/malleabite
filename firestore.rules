rules_version = '2';
// Updated: relaxed todos update rule for linking operations
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper function to check if user owns the document
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Helper function to check if the new document has the correct userId
    function isValidOwner() {
      return isAuthenticated() && request.resource.data.userId == request.auth.uid;
    }

    // Helper function to validate string field
    function isValidString(field, minLen, maxLen) {
      return request.resource.data[field] is string 
        && request.resource.data[field].size() >= minLen 
        && request.resource.data[field].size() <= maxLen;
    }

    // Helper function to check rate limiting (basic implementation)
    function isNotRateLimited() {
      // Check if last update was at least 1 second ago
      return !('lastUpdate' in resource.data) || 
        request.time > resource.data.lastUpdate + duration.value(1, 's');
    }

    // Helper function to validate email
    function isValidEmail(email) {
      return email.matches('.*@.*\\..*');
    }

    // Helper: check if authenticated user is a collaborator on a todo list
    function isListCollaborator(listId) {
      return isAuthenticated()
        && exists(/databases/$(database)/documents/todo_lists/$(listId))
        && 'collaboratorIds' in get(/databases/$(database)/documents/todo_lists/$(listId)).data
        && request.auth.uid in get(/databases/$(database)/documents/todo_lists/$(listId)).data.collaboratorIds;
    }

    // Helper: check if authenticated user owns the todo list (not the item)
    function isListOwner(listId) {
      return isAuthenticated()
        && exists(/databases/$(database)/documents/todo_lists/$(listId))
        && get(/databases/$(database)/documents/todo_lists/$(listId)).data.userId == request.auth.uid;
    }


    // Users collection - keyed by User ID
    match /users/{userId} {
      // Own profile: full read. Others: allow list queries for invite email lookup.
      allow get: if isOwner(userId);
      allow list: if isAuthenticated();
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) 
        && request.resource.data.keys().hasAll(['userId', 'email', 'createdAt']);
      allow update: if isOwner(userId) 
        && request.resource.data.userId == resource.data.userId // Can't change userId
        && isNotRateLimited();
      allow delete: if isOwner(userId);

      // Calendar Groups (subcollection)
      match /calendarGroups/{groupId} {
        allow read, write: if isOwner(userId);
      }

      // Connected Calendars (subcollection)
      match /connectedCalendars/{calendarId} {
        allow read, write: if isOwner(userId);
      }

      // Calendar Preferences (subcollection)
      match /calendarPreferences/{prefId} {
        allow read, write: if isOwner(userId);
      }

      // Synced Events from external calendars (subcollection)
      match /syncedEvents/{eventId} {
        allow read, write: if isOwner(userId);
      }

      // Calendar Templates (subcollection)
      match /calendarTemplates/{templateId} {
        allow read, write: if isOwner(userId);
      }
    }

    // Calendar Events
    match /calendar_events/{eventId} {
      allow read, delete: if isOwner(resource.data.userId);
      allow create: if isValidOwner()
        && isValidString('title', 1, 200)
        && request.resource.data.startAt is timestamp
        && request.resource.data.endAt is timestamp;
      allow update: if isOwner(resource.data.userId)
        && request.resource.data.userId == resource.data.userId; // Can't change owner
    }

    // Todos
    match /todos/{todoId} {
      allow read, delete: if isOwner(resource.data.userId);
      allow create: if isValidOwner()
        && isValidString('text', 1, 500)
        && request.resource.data.keys().hasAll(['userId', 'text']);
      allow update: if isOwner(resource.data.userId)
        && request.resource.data.userId == resource.data.userId;
    }

    // Todo Lists (polymorphic todo containers)
    match /todo_lists/{listId} {
      allow read: if isOwner(resource.data.userId)
        || (isAuthenticated()
            && 'collaboratorIds' in resource.data
            && request.auth.uid in resource.data.collaboratorIds);
      allow delete: if isOwner(resource.data.userId);
      allow create: if isValidOwner()
        && isValidString('name', 1, 100)
        && request.resource.data.keys().hasAll(['userId', 'name']);
      allow update: if (isOwner(resource.data.userId)
          && request.resource.data.userId == resource.data.userId
          && isValidString('name', 1, 100)
          && isNotRateLimited())
        // Allow collaborator array updates (accept invite flow)
        || (isAuthenticated()
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['collaboratorIds']));
    }

    // Todo Items (for polymorphic todo lists)
    match /todo_items/{itemId} {
      allow read: if isOwner(resource.data.userId)
        || isListCollaborator(resource.data.listId)
        || isListOwner(resource.data.listId);
      allow delete: if isOwner(resource.data.userId)
        || isListCollaborator(resource.data.listId)
        || isListOwner(resource.data.listId);
      allow create: if (isValidOwner()
          && isValidString('text', 1, 500)
          && request.resource.data.keys().hasAll(['userId', 'text', 'listId']))
        // Allow collaborators (editors) to add todos
        || (isAuthenticated()
            && isListCollaborator(request.resource.data.listId)
            && isValidString('text', 1, 500));
      allow update: if (isOwner(resource.data.userId)
          && request.resource.data.userId == resource.data.userId)
        || isListCollaborator(resource.data.listId)
        || isListOwner(resource.data.listId);
    }

    // Calendar Snapshots
    match /calendar_snapshots/{snapshotId} {
      allow read, delete: if isOwner(resource.data.userId);
      allow create: if isValidOwner()
        && isValidString('name', 1, 200)
        && request.resource.data.keys().hasAll(['userId', 'name', 'eventCount']);
      allow update: if isOwner(resource.data.userId)
        && request.resource.data.userId == resource.data.userId;
    }

    // Snapshot Events (saved calendar events)
    match /snapshot_events/{eventId} {
      allow read, write: if isAuthenticated();
      // Note: We allow broader access here since snapshots are keyed by snapshotId
      // which is only known to the owner. Consider adding snapshotId validation
    }

    // Eisenhower Items
    match /eisenhower_items/{itemId} {
      allow read, delete: if isOwner(resource.data.userId);
      allow create: if isValidOwner()
        && isValidString('text', 1, 200);
      allow update: if isOwner(resource.data.userId)
        && request.resource.data.userId == resource.data.userId
        && isNotRateLimited();
    }

    // Reminders
    match /reminders/{reminderId} {
      allow read, delete: if isOwner(resource.data.userId);
      allow create: if isValidOwner()
        && isValidString('title', 1, 200)
        && request.resource.data.reminderTime is timestamp;
      allow update: if isOwner(resource.data.userId)
        && request.resource.data.userId == resource.data.userId
        && isNotRateLimited();
    }

    // Alarms
    match /alarms/{alarmId} {
      allow read, delete: if isOwner(resource.data.userId);
      allow create: if isValidOwner()
        && isValidString('title', 1, 200)
        && request.resource.data.keys().hasAll(['userId', 'title', 'time', 'enabled']);
      allow update: if isOwner(resource.data.userId)
        && request.resource.data.userId == resource.data.userId
        && isNotRateLimited();
    }

    // Entity Links — unified relationship graph between entities
    match /entity_links/{linkId} {
      allow read, delete: if isOwner(resource.data.userId);
      allow create: if isValidOwner()
        && request.resource.data.keys().hasAll(['userId', 'sourceType', 'sourceId', 'targetType', 'targetId', 'relation']);
      allow update: if isOwner(resource.data.userId)
        && request.resource.data.userId == resource.data.userId;
    }

    // Sidebar Pages (for multi-page sidebar system)
    match /sidebar_pages/{pageId} {
      // For list queries, we need to allow read if the query filters by userId
      allow read: if isAuthenticated() && 
        (resource == null || resource.data.userId == request.auth.uid);
      allow delete: if isOwner(resource.data.userId);
      allow create: if isValidOwner()
        && isValidString('title', 1, 100)
        && request.resource.data.keys().hasAll(['userId', 'title', 'icon', 'modules']);
      allow update: if isOwner(resource.data.userId)
        && request.resource.data.userId == resource.data.userId
        && isValidString('title', 1, 100)
        && isNotRateLimited();
    }

    // Invites
    match /invites/{inviteId} {
      // Allow read if user is sender or recipient
      allow read: if isAuthenticated() && 
        (resource.data.senderId == request.auth.uid || 
         resource.data.recipientId == request.auth.uid || 
         resource.data.recipientEmail == request.auth.token.email);
      allow delete: if isAuthenticated() && resource.data.senderId == request.auth.uid;
      allow create: if isAuthenticated()
        && request.resource.data.senderId == request.auth.uid
        && isValidString('eventTitle', 1, 200);
      allow update: if isAuthenticated() && 
        (resource.data.senderId == request.auth.uid || 
         resource.data.recipientId == request.auth.uid || 
         resource.data.recipientEmail == request.auth.token.email)
        && isNotRateLimited();
    }

    // AI Suggestions
    match /ai_suggestions/{suggestionId} {
      allow read, delete: if isOwner(resource.data.userId);
      allow create: if isValidOwner();
      allow update: if isOwner(resource.data.userId)
        && request.resource.data.userId == resource.data.userId
        && isNotRateLimited();
    }

    // Pomodoro Sessions
    match /pomodoro_sessions/{sessionId} {
      allow read, delete: if isOwner(resource.data.userId);
      allow create: if isValidOwner()
        && request.resource.data.duration is number
        && request.resource.data.duration > 0
        && request.resource.data.duration <= 3600; // Max 1 hour
      allow update: if isOwner(resource.data.userId)
        && request.resource.data.userId == resource.data.userId
        && isNotRateLimited();
    }

    // Module Instances
    match /module_instances/{instanceId} {
      allow read, delete: if isOwner(resource.data.userId);
      allow create: if isValidOwner();
      allow update: if isOwner(resource.data.userId)
        && request.resource.data.userId == resource.data.userId
        && isNotRateLimited();
    }

    // Templates (read-only for all authenticated users, write only for owners)
    match /templates/{templateId} {
      allow read: if isAuthenticated();
      allow create: if isValidOwner()
        && isValidString('name', 1, 100);
      allow update, delete: if isOwner(resource.data.userId)
        && isNotRateLimited();
    }

    // Patterns (similar to templates)
    match /patterns/{patternId} {
      allow read: if isAuthenticated();
      allow create: if isValidOwner();
      allow update, delete: if isOwner(resource.data.userId)
        && isNotRateLimited();
    }

    // Analytics data — docs are keyed as {userId}_{date}
    // Accept both user_id and userId field names for backward compatibility
    match /analytics/{docId} {
      allow read: if isAuthenticated() && (
        (resource != null && resource.data.user_id == request.auth.uid) ||
        (resource != null && resource.data.userId == request.auth.uid)
      );
      allow create: if isAuthenticated() && (
        request.resource.data.user_id == request.auth.uid ||
        request.resource.data.userId == request.auth.uid
      );
      allow update: if isAuthenticated() && (
        (resource.data.user_id == request.auth.uid) ||
        (resource.data.userId == request.auth.uid)
      );
      allow delete: if isAuthenticated() && (
        (resource.data.user_id == request.auth.uid) ||
        (resource.data.userId == request.auth.uid)
      );
    }

    // Goals
    match /goals/{goalId} {
      allow read, delete: if isOwner(resource.data.userId);
      allow create: if isValidOwner()
        && isValidString('title', 1, 200)
        && request.resource.data.keys().hasAll(['userId', 'title', 'category']);
      allow update: if isOwner(resource.data.userId)
        && request.resource.data.userId == resource.data.userId;
    }

    // Goal Sessions — progress entries for each goal
    match /goal_sessions/{sessionId} {
      allow read, delete: if isOwner(resource.data.userId);
      allow create: if isValidOwner()
        && request.resource.data.keys().hasAll(['userId', 'goalId']);
      allow update: if isOwner(resource.data.userId)
        && request.resource.data.userId == resource.data.userId;
    }

    // Notification Preferences
    match /notification_preferences/{prefId} {
      allow get: if request.auth != null && prefId == request.auth.uid;
      allow list: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow delete: if isOwner(resource.data.userId);
      allow create: if isValidOwner();
      allow update: if isOwner(resource.data.userId)
        && request.resource.data.userId == resource.data.userId;
    }

    // Scheduled Notifications
    match /scheduled_notifications/{notifId} {
      allow get: if request.auth != null
        && resource.data.userId == request.auth.uid;
      allow list: if isOwner(resource.data.userId);
      allow delete: if isOwner(resource.data.userId);
      allow create: if isValidOwner();
      allow update: if isOwner(resource.data.userId)
        && request.resource.data.userId == resource.data.userId;
    }

    // Calendars
    match /calendars/{calendarId} {
      allow read: if isAuthenticated() && 
        (resource == null || resource.data.userId == request.auth.uid);
      allow delete: if isOwner(resource.data.userId);
      allow create: if isValidOwner()
        && isValidString('name', 1, 100);
      allow update: if isOwner(resource.data.userId)
        && request.resource.data.userId == resource.data.userId
        && isNotRateLimited();
    }

    // Subscriptions - user can read/write their own subscription
    match /subscriptions/{userId} {
      allow read: if isOwner(userId);
      allow create: if isAuthenticated() && request.auth.uid == userId;
      allow update: if isOwner(userId);
      allow delete: if isOwner(userId);
    }

    // Usage tracking - user can read/write their own usage data
    match /usage/{userId} {
      allow read: if isOwner(userId);
      allow create: if isAuthenticated() && request.auth.uid == userId;
      allow update: if isOwner(userId);
      allow delete: if isOwner(userId);
    }

    // User Settings (working hours, preferences, etc.) - keyed by User ID
    match /user_settings/{userId} {
      allow read: if isOwner(userId);
      allow create: if isAuthenticated() && request.auth.uid == userId;
      allow update: if isOwner(userId);
      allow delete: if isOwner(userId);
    }

    // AI Memory - persistent AI preferences, patterns, and observations per user
    match /ai_memory/{userId} {
      allow read: if isOwner(userId);
      allow create: if isAuthenticated() && request.auth.uid == userId;
      allow update: if isOwner(userId);
      allow delete: if isOwner(userId);
    }

    // Booking Pages - owner can manage their own booking pages
    match /booking_pages/{pageId} {
      allow read: if isAuthenticated() &&
        resource.data.userId == request.auth.uid;
      allow create: if isValidOwner();
      allow update: if isOwner(resource.data.userId)
        && request.resource.data.userId == resource.data.userId
        && isNotRateLimited();
      allow delete: if isOwner(resource.data.userId);
    }

    // Teams - members can read, owners/admins can write
    match /teams/{teamId} {
      allow read: if isAuthenticated() &&
        (resource.data.ownerId == request.auth.uid ||
         request.auth.uid in resource.data.memberIds);
      allow create: if isAuthenticated() &&
        request.resource.data.ownerId == request.auth.uid;
      allow update: if isAuthenticated() &&
        request.auth.uid in resource.data.memberIds;
      allow delete: if isAuthenticated() &&
        resource.data.ownerId == request.auth.uid;
    }

    // Team Invites - recipients can read/respond, team members can create
    match /team_invites/{inviteId} {
      allow read: if isAuthenticated() &&
        (resource.data.email == request.auth.token.email ||
         resource.data.invitedBy == request.auth.uid);
      allow create: if isAuthenticated() &&
        request.resource.data.invitedBy == request.auth.uid;
      allow update: if isAuthenticated() &&
        (resource.data.email == request.auth.token.email ||
         resource.data.invitedBy == request.auth.uid);
      allow delete: if isAuthenticated() &&
        resource.data.invitedBy == request.auth.uid;
    }

    // Customers - Stripe customer mapping (user can read their own)
    match /customers/{userId} {
      allow read: if isOwner(userId);
      allow create: if isAuthenticated() && request.auth.uid == userId;
      allow update: if isOwner(userId);
      allow delete: if false; // Don't allow users to delete customer records
    }

    // WhatsApp link codes — server-managed (Cloud Functions write, no client access)
    match /whatsapp_link_codes/{code} {
      allow read, write: if false;
    }

    // WhatsApp users mapping — server-managed (Cloud Functions write, no client access)
    match /whatsapp_users/{phone} {
      allow read, write: if false;
    }

    // WhatsApp sessions — server-managed (pending actions, undo tracking)
    match /whatsapp_sessions/{phone} {
      allow read, write: if false;
    }

    // Module Shares — collaboration state per module instance
    match /module_shares/{instanceId} {
      // resource == null means the doc doesn't exist yet — allow authenticated
      // users to check existence so inviteToModule / getOrCreateShareToken can
      // read before deciding whether to create.
      allow read: if isAuthenticated() && (
        resource == null ||
        resource.data.ownerId == request.auth.uid ||
        ('collaboratorIds' in resource.data && request.auth.uid in resource.data.collaboratorIds)
      );
      allow create: if isAuthenticated()
        && request.resource.data.ownerId == request.auth.uid;
      allow update: if isAuthenticated() && (
        resource == null ||
        resource.data.ownerId == request.auth.uid ||
        // Allow adding self as collaborator (accept invite)
        ('collaboratorIds' in request.resource.data
          && request.auth.uid in request.resource.data.collaboratorIds)
      );
      allow delete: if isAuthenticated()
        && resource.data.ownerId == request.auth.uid;
    }

    // Module Invites — invitations to collaborate on a module
    match /module_invites/{inviteId} {
      // get: strict — only sender or recipient
      allow get: if isAuthenticated() && (
        resource.data.senderId == request.auth.uid ||
        resource.data.recipientEmail == request.auth.token.email ||
        resource.data.recipientUserId == request.auth.uid
      );
      // list: allow authenticated queries — client always filters by moduleInstanceId
      // (which is owned by the sender, so only their data is returned in practice)
      allow list: if isAuthenticated();
      allow create: if isAuthenticated()
        && request.resource.data.senderId == request.auth.uid;
      allow update: if isAuthenticated() && (
        resource.data.senderId == request.auth.uid ||
        resource.data.recipientEmail == request.auth.token.email ||
        resource.data.recipientUserId == request.auth.uid
      );
      allow delete: if isAuthenticated()
        && resource.data.senderId == request.auth.uid;
    }

    // Notifications — in-app notifications (invites, acceptances, etc.)
    match /notifications/{notificationId} {
      allow read: if isAuthenticated()
        && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated();
      allow update: if isAuthenticated()
        && resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated()
        && resource.data.userId == request.auth.uid;
    }

    // Share Tokens — capability tokens for link-based module sharing
    // Doc ID = UUID token; anyone who knows the token can read module metadata
    match /share_tokens/{token} {
      allow read: if true; // public — the token IS the capability
      allow create: if isAuthenticated()
        && request.resource.data.ownerId == request.auth.uid;
      allow delete: if isAuthenticated()
        && resource.data.ownerId == request.auth.uid;
      allow update: if false;
    }

    // Group Meet Sessions — public read (link sharing), auth required to create
    match /group_meets/{sessionId} {
      // Anyone with the link can read (public meet page for guests)
      allow read: if true;
      // Only authenticated users can create, and only as organizer
      allow create: if isAuthenticated() &&
        request.resource.data.organizerId == request.auth.uid;
      // Organizer can update anything; unauthenticated guests can update
      // participants array only (for availability submission via public page)
      allow update: if
        (isAuthenticated() && resource.data.organizerId == request.auth.uid) ||
        resource.data.status == 'collecting';
      allow delete: if isAuthenticated() &&
        resource.data.organizerId == request.auth.uid;
    }
  }
}
